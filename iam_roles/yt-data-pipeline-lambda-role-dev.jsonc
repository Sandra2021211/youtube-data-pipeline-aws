// This is the IAM policy for the Lambda role used in the YouTube data pipeline in the development environment.

// This role also contains AWSLambdaBasicExecutionRole permissions (AWS Managed policy), which are required for Lambda to function properly. These permissions are not included in this policy document, but are attached to the role separately in AWS.


{
	"Version": "2012-10-17",
	"Statement": [
		{
			"Sid": "S3Access",
			"Effect": "Allow",
			"Action": [
				"s3:GetObject",
				"s3:PutObject",
				"s3:ListBucket",
				"s3:GetBucketLocation"
			],
			"Resource": [
				"arn:aws:s3:::yt-data-pipeline-bronze-ap-south2-dev/*",
				"arn:aws:s3:::yt-data-pipeline-bronze-ap-south2-dev",
				"arn:aws:s3:::yt-data-pipeline-silver-ap-south2-dev/*",
				"arn:aws:s3:::yt-data-pipeline-silver-ap-south2-dev",
				"arn:aws:s3:::yt-data-pipeline-glue-athena-query-results-ap-south2",
				"arn:aws:s3:::yt-data-pipeline-glue-athena-query-results-ap-south2/*"
			]
		},
		{
			"Sid": "GlueAccess",
			"Effect": "Allow",
			"Action": [
				"glue:GetTable",
				"glue:GetDatabase",
				"glue:CreateTable",
				"glue:UpdateTable",
				"glue:GetPartitions",
				"glue:CreatePartition",
				"glue:BatchCreatePartition"
			],
			"Resource": "*"
		},
		{
			"Sid": "SNSAccess",
			"Effect": "Allow",
			"Action": "sns:Publish",
			"Resource": "arn:aws:sns:ap-south-2:267923959886:yt-data-pipeline-alerts-dev"
		},
		{
			"Sid": "AthenaAccess",
			"Effect": "Allow",
			"Action": [
				"athena:StartQueryExecution",
				"athena:GetQueryExecution",
				"athena:GetQueryResults",
				"athena:GetWorkGroup"
			],
			"Resource": "*"
		}
	]
}